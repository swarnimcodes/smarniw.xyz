<!DOCTYPE html>
<html data-theme="dracula">

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>
      // Empty script tag helps reduce Flash of Unstyled Contents in firefox!
      // See: https://bugzilla.mozilla.org/show_bug.cgi?id=1404468
      // See: https://www.youtube.com/watch?v=RouECKT4u_Y
    </script>

    <title inertia>
      Swarnim
    </title>

    @viteReactRefresh()
    @inertiaHead()
    @vite(['inertia/app/app.tsx', `inertia/pages/${page.component}.tsx`])
  </head>

  <body class="min-h-screen w-screen font-sans">
    @inertia()
  </body>
  <script>
    
  </script>

</html>
